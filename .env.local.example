# =============================================================
# OpenPlay Pickleball — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# Supabase Project URL (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (NEVER expose to browser — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used for QR code generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000
